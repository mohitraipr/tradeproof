{
  "name": "bestseller-backend",
  "version": "1.0.0",
  "description": "AI-powered B2B fashion bestseller API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "monitor": "tsx src/agents/category-monitor.ts",
    "crawl": "tsx src/agents/crawler.ts",
    "enrich": "tsx src/agents/enricher.ts",
    "rank": "tsx src/agents/ranker.ts",
    "pipeline": "tsx src/agents/pipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "puppeteer": "^24.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
